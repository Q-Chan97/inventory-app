<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" href="/icons/favicon.svg">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include("./partials/header.ejs") %>
    <main>
        <div class="page-container">
            <div class="category-title">
                <h3><%= title %></h3>
            </div>
            <a href="/cat/new" class="new-item-button">+ Add Item</a>
            <section class="content-container">
                <% if (inventory) { %>
                    <% inventory.forEach((item) => { %>
                        <a class="item-anchor" href="/cat/<%= catLink %>/<%= item.id %>">
                            <article class="item-container">
                                <div class="cat-bottle-image-container">
                                    <img src="/images/bottle.jpg" alt="bottle image">
                                </div>
                                <div class="info-container">
                                    <div class="info">
                                        <h4><%= item.name %></h4>
                                        <span class="row">
                                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#1f1f1f"><path d="m233-120 93-304L80-600h304l96-320 96 320h304L634-424l93 304-247-188-247 188Z"/></svg>
                                            <p><%= item.rating %></p>
                                        </span>
                                        <p><%= item.proof %> proof</p>
                                    </div>
                                </div>
                                <span class="row r-l-pos">
                                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#1f1f1f"><path d="M240-120v-80h200v-200L120-760v-80h720v80L520-400v200h200v80H240Zm58-560h364l72-80H226l72 80Z"/></svg>
                                    <p><%= item.quantity %></p>
                                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#1f1f1f"><path d="M320-240h320v-80H320v80Zm0-160h320v-80H320v80ZM240-80q-33 0-56.5-23.5T160-160v-640q0-33 23.5-56.5T240-880h320l240 240v480q0 33-23.5 56.5T720-80H240Zm280-520h200L520-800v200Z"/></svg>
                                </span>
                            </article>
                        </a>
                    <% }) %>
                <% } %>
            </section>
        </div>
    </main>
    <%- include("./partials/footer.ejs") %>
</body>
</html>